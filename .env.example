# Copy to .env and adjust. All values are OPTIONAL — sensible defaults apply.

# Runtime environment: development | production | test
NODE_ENV=development

# Port the HTTP server listens on (0-65535)
PORT=3000

# Base URL of the upstream user directory
USERS_API_BASE_URL=https://dummyjson.com

# Upstream request timeout in milliseconds
USERS_API_TIMEOUT_MS=5000
